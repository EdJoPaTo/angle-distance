{
	"name": "angle-distance",
	"version": "2.0.0",
	"description": "Calculates the difference between two angles",
	"keywords": [
		"arc",
		"angle",
		"angular",
		"degree",
		"radian",
		"distance",
		"difference"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/EdJoPaTo/angle-distance.git"
	},
	"author": {
		"name": "EdJoPaTo",
		"email": "angle-distance-npm-package@edjopato.de",
		"url": "https://edjopato.de"
	},
	"scripts": {
		"build": "del-cli dist && tsc",
		"prepack": "npm run build",
		"test": "tsc --sourceMap && xo && c8 --all node --test --enable-source-maps"
	},
	"type": "module",
	"engines": {
		"node": ">=12"
	},
	"devDependencies": {
		"@types/node": "^18.19.3",
		"c8": "^10.1.2",
		"del-cli": "^6.0.0",
		"typescript": "^6.0.2",
		"xo": "^1.2.2"
	},
	"files": [
		"dist",
		"!*.test.*",
		"!test.*"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"xo": [
		{
			"rules": {
				"@typescript-eslint/prefer-readonly-parameter-types": "error"
			}
		},
		{
			"files": [
				"**/*.test.*",
				"**/test.*"
			],
			"rules": {
				"@typescript-eslint/prefer-readonly-parameter-types": "off"
			}
		}
	]
}
